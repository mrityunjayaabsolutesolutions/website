---
import { process } from '../data/site';
---

<section class="border-t border-white/5 bg-navy-900/30 py-24">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="reveal mx-auto max-w-2xl text-center">
			<p class="font-sans text-sm font-semibold uppercase tracking-[0.2em] text-teal-400">How we work</p>
			<h2 class="mt-3 font-sans text-3xl font-bold tracking-tight text-white sm:text-4xl">
				A clear path from idea to impact
			</h2>
		</div>

		<ol class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
			{
				process.map((step, i) => (
					<li
						class="reveal relative rounded-2xl border border-white/10 bg-navy-800/50 p-6"
						style={`transition-delay: ${i * 70}ms`}
					>
						<span class="font-sans text-4xl font-extrabold text-teal-500/30">{step.step}</span>
						<h3 class="mt-4 font-sans text-lg font-semibold text-white">{step.title}</h3>
						<p class="mt-2 text-sm leading-relaxed text-slate-500">{step.description}</p>
					</li>
				))
			}
		</ol>
	</div>
</section>
