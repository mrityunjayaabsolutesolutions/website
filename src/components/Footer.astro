---
import { nav, site } from '../data/site';
---

<footer class="border-t border-white/5 bg-navy-900/50 py-12">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
			<div class="flex items-center gap-4">
				<img
					src="/logo.png"
					alt=""
					class="h-12 w-auto max-w-[140px] object-contain opacity-90"
					width="140"
					height="48"
					loading="lazy"
				/>
				<div>
					<p class="font-sans text-lg font-bold text-white">{site.name}</p>
					<p class="mt-1 text-sm text-slate-500">{site.tagline}</p>
				</div>
			</div>
			<nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer navigation">
				{
					nav.map((item) => (
						<a href={item.href} class="text-sm text-slate-500 transition-colors hover:text-white">
							{item.label}
						</a>
					))
				}
			</nav>
		</div>
		<p class="mt-8 border-t border-white/5 pt-8 text-center text-xs text-slate-600 md:text-left">
			© {new Date().getFullYear()} {site.name}. All rights reserved.
		</p>
	</div>
</footer>
