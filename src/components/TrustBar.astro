---
import { stats } from '../data/site';
---

<section class="border-y border-white/5 bg-navy-900/50 py-10" aria-label="Company highlights">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="reveal grid grid-cols-2 gap-6 md:grid-cols-4">
			{
				stats.map((stat, i) => (
					<div
						class="text-center md:text-left"
						style={`transition-delay: ${i * 80}ms`}
					>
						<p class="font-sans text-3xl font-bold text-white">{stat.value}</p>
						<p class="mt-1 text-sm text-slate-500">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
