---
import { about } from '../data/site';
---

<section id="about" class="py-24">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="reveal mx-auto max-w-3xl text-center">
			<p class="font-sans text-sm font-semibold uppercase tracking-[0.2em] text-teal-400">Who we are</p>
			<h2 class="mt-3 font-sans text-3xl font-bold tracking-tight text-white sm:text-4xl">
				Your partner in digital transformation
			</h2>
		</div>
		<div class="reveal mx-auto mt-10 max-w-3xl" style="transition-delay: 100ms">
			{
				about.split('\n\n').map((paragraph) => (
					<p class="mt-6 text-base leading-relaxed text-slate-400 first:mt-0">{paragraph}</p>
				))
			}
		</div>
	</div>
</section>
