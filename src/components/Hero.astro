---
import { site } from '../data/site';
import Icon from './Icon.astro';
---

<section id="home" class="relative flex min-h-screen items-center pt-24 pb-16">
	<div class="mx-auto grid max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:px-8">
		<div class="reveal">
			<p
				class="mb-4 inline-flex items-center gap-2 rounded-full border border-teal-500/30 bg-teal-500/10 px-4 py-1.5 font-sans text-xs font-semibold uppercase tracking-[0.2em] text-teal-400"
			>
				<span class="h-1.5 w-1.5 rounded-full bg-teal-400" aria-hidden="true"></span>
				{site.tagline}
			</p>
			<h1 class="font-sans text-4xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
				<span class="text-gradient">{site.headline}</span>
			</h1>
			<p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
				{site.subheadline}
			</p>
			<div class="mt-10 flex flex-wrap gap-4">
				<a
					href="#contact"
					class="inline-flex items-center gap-2 rounded-xl bg-teal-500 px-6 py-3.5 font-sans text-sm font-semibold text-navy-950 transition-all duration-200 hover:bg-teal-400 hover:shadow-xl hover:shadow-teal-500/30"
				>
					Start a project
					<Icon name="arrow" class="h-4 w-4" />
				</a>
				<a
					href="#services"
					class="inline-flex items-center gap-2 rounded-xl border border-white/15 px-6 py-3.5 font-sans text-sm font-semibold text-white transition-all duration-200 hover:border-teal-500/50 hover:bg-white/5"
				>
					Explore services
				</a>
			</div>
		</div>

		<div class="reveal relative lg:justify-self-end" style="transition-delay: 120ms">
			<div class="glass relative overflow-hidden rounded-3xl p-8 shadow-2xl shadow-black/40">
				<div
					class="absolute -right-8 -top-8 h-40 w-40 rounded-full bg-teal-500/20 blur-3xl"
					aria-hidden="true"
				>
				</div>
				<div
					class="absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-amber-400/10 blur-3xl"
					aria-hidden="true"
				>
				</div>
				<p class="font-sans text-sm font-semibold uppercase tracking-wider text-teal-400">
					What we deliver
				</p>
				<ul class="mt-6 space-y-4">
					<li class="flex items-start gap-3">
						<span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-teal-500/20 text-teal-400">✓</span>
						<span class="text-sm leading-relaxed text-slate-300">Custom software & enterprise web applications</span>
					</li>
					<li class="flex items-start gap-3">
						<span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-teal-500/20 text-teal-400">✓</span>
						<span class="text-sm leading-relaxed text-slate-300">Mobile, ecommerce & enterprise mobility</span>
					</li>
					<li class="flex items-start gap-3">
						<span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-teal-500/20 text-teal-400">✓</span>
						<span class="text-sm leading-relaxed text-slate-300">Testing, analytics & managed support</span>
					</li>
				</ul>
				<div class="mt-8 grid grid-cols-2 gap-3 border-t border-white/10 pt-8">
					<div>
						<p class="font-sans text-2xl font-bold text-white">Quality</p>
						<p class="text-xs text-slate-500">Uncompromising standards</p>
					</div>
					<div>
						<p class="font-sans text-2xl font-bold text-white">Value</p>
						<p class="text-xs text-slate-500">Cost-effective delivery</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
