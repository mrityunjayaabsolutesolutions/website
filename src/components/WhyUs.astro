---
import { whyUs } from '../data/site';
---

<section id="why-us" class="py-24">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="reveal mx-auto max-w-2xl text-center">
			<p class="font-sans text-sm font-semibold uppercase tracking-[0.2em] text-teal-400">Why choose us</p>
			<h2 class="mt-3 font-sans text-3xl font-bold tracking-tight text-white sm:text-4xl">
				Built on trust, delivery, and results
			</h2>
		</div>

		<div class="mt-14 grid gap-6 sm:grid-cols-2">
			{
				whyUs.map((item, i) => (
					<article
						class="reveal glass rounded-2xl border-l-4 border-l-teal-500 p-8"
						style={`transition-delay: ${i * 80}ms`}
					>
						<h3 class="font-sans text-xl font-semibold text-white">{item.title}</h3>
						<p class="mt-3 text-sm leading-relaxed text-slate-400">{item.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
