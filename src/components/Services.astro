---
import { services } from '../data/site';
import Icon from './Icon.astro';
---

<section id="services" class="border-t border-white/5 bg-navy-900/30 py-24">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="reveal mx-auto max-w-2xl text-center">
			<p class="font-sans text-sm font-semibold uppercase tracking-[0.2em] text-teal-400">Our services</p>
			<h2 class="mt-3 font-sans text-3xl font-bold tracking-tight text-white sm:text-4xl">
				End-to-end IT solutions
			</h2>
			<p class="mt-4 text-slate-400">
				From strategy to support — comprehensive capabilities to build, scale, and secure your technology stack.
			</p>
		</div>

		<div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
			{
				services.map((service, i) => (
					<article
						class="reveal group glass rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:border-teal-500/30 hover:shadow-xl hover:shadow-teal-500/5"
						style={`transition-delay: ${(i % 4) * 60}ms`}
					>
						<div class="mb-4 inline-flex rounded-xl bg-teal-500/15 p-3 text-teal-400 transition-colors group-hover:bg-teal-500/25">
							<Icon name={service.icon} class="h-6 w-6" />
						</div>
						<h3 class="font-sans text-lg font-semibold text-white">{service.title}</h3>
						<p class="mt-2 text-sm leading-relaxed text-slate-500">{service.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
