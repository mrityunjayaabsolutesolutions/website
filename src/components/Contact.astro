---
import { site } from '../data/site';
import Icon from './Icon.astro';

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
const formEnabled = accessKey.length > 0;
---

<section id="contact" class="py-24">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="reveal grid gap-12 lg:grid-cols-2 lg:items-start">
			<div>
				<p class="font-sans text-sm font-semibold uppercase tracking-[0.2em] text-teal-400">Contact</p>
				<h2 class="mt-3 font-sans text-3xl font-bold tracking-tight text-white sm:text-4xl">
					Let's discuss your next project
				</h2>
				<p class="mt-4 max-w-md text-slate-400">
					Tell us about your goals. We'll respond with how we can help — typically within one business day.
				</p>

				<ul class="mt-10 space-y-5">
					<li>
						<a
							href={`mailto:${site.email}`}
							class="group flex items-center gap-4 text-slate-300 transition-colors hover:text-white"
						>
							<span class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal-500/15 text-teal-400">
								<Icon name="mail" class="h-5 w-5" />
							</span>
							<span>
								<span class="block text-xs text-slate-500">Email</span>
								<span class="text-sm font-medium">{site.email}</span>
							</span>
						</a>
					</li>
					<li>
						<a
							href={`tel:${site.phoneTel}`}
							class="flex items-center gap-4 text-slate-300 transition-colors hover:text-white"
						>
							<span class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal-500/15 text-teal-400">
								<Icon name="phone" class="h-5 w-5" />
							</span>
							<span>
								<span class="block text-xs text-slate-500">Phone</span>
								<span class="text-sm font-medium">{site.phone}</span>
							</span>
						</a>
					</li>
					<li class="flex items-center gap-4 text-slate-300">
						<span class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal-500/15 text-teal-400">
							<Icon name="map" class="h-5 w-5" />
						</span>
						<span>
							<span class="block text-xs text-slate-500">Location</span>
							<span class="text-sm font-medium">{site.location}</span>
						</span>
					</li>
				</ul>
			</div>

			<div class="reveal glass rounded-3xl p-8" style="transition-delay: 100ms">
				{
					formEnabled ? (
						<form
							action="https://api.web3forms.com/submit"
							method="POST"
							class="space-y-5"
							id="contact-form"
						>
							<input type="hidden" name="access_key" value={accessKey} />
							<input type="hidden" name="subject" value="New inquiry from MAS website" />
							<input type="checkbox" name="botcheck" class="hidden" style="display:none" />

							<div>
								<label for="name" class="mb-1.5 block text-sm font-medium text-slate-300">
									Name
								</label>
								<input
									id="name"
									name="name"
									type="text"
									required
									class="w-full rounded-xl border border-white/10 bg-navy-900/80 px-4 py-3 text-sm text-white outline-none transition-colors placeholder:text-slate-600 focus:border-teal-500/50 focus:ring-2 focus:ring-teal-500/20"
									placeholder="Your name"
								/>
							</div>
							<div>
								<label for="email" class="mb-1.5 block text-sm font-medium text-slate-300">
									Email
								</label>
								<input
									id="email"
									name="email"
									type="email"
									required
									class="w-full rounded-xl border border-white/10 bg-navy-900/80 px-4 py-3 text-sm text-white outline-none transition-colors placeholder:text-slate-600 focus:border-teal-500/50 focus:ring-2 focus:ring-teal-500/20"
									placeholder="you@company.com"
								/>
							</div>
							<div>
								<label for="company" class="mb-1.5 block text-sm font-medium text-slate-300">
									Company
								</label>
								<input
									id="company"
									name="company"
									type="text"
									class="w-full rounded-xl border border-white/10 bg-navy-900/80 px-4 py-3 text-sm text-white outline-none transition-colors placeholder:text-slate-600 focus:border-teal-500/50 focus:ring-2 focus:ring-teal-500/20"
									placeholder="Company name (optional)"
								/>
							</div>
							<div>
								<label for="message" class="mb-1.5 block text-sm font-medium text-slate-300">
									Message
								</label>
								<textarea
									id="message"
									name="message"
									rows={5}
									required
									class="w-full resize-y rounded-xl border border-white/10 bg-navy-900/80 px-4 py-3 text-sm text-white outline-none transition-colors placeholder:text-slate-600 focus:border-teal-500/50 focus:ring-2 focus:ring-teal-500/20"
									placeholder="Tell us about your project..."
								/>
							</div>
							<button
								type="submit"
								class="w-full rounded-xl bg-teal-500 px-6 py-3.5 font-sans text-sm font-semibold text-navy-950 transition-all duration-200 hover:bg-teal-400"
							>
								Send message
							</button>
							<p id="form-status" class="hidden text-center text-sm" role="status" />
						</form>
					) : (
						<div class="space-y-4 text-sm text-slate-400">
							<p>
								Email us directly at{' '}
								<a href={`mailto:${site.email}`} class="text-teal-400 hover:text-teal-300">
									{site.email}
								</a>
							</p>
							<p class="rounded-xl border border-amber-400/20 bg-amber-400/5 p-4 text-amber-200/90">
								To enable the contact form, add your free Web3Forms key to{' '}
								<code class="text-teal-300">.env</code> as{' '}
								<code class="text-teal-300">PUBLIC_WEB3FORMS_ACCESS_KEY</code> and rebuild.
							</p>
						</div>
					)
				}
			</div>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById('contact-form');
	const status = document.getElementById('form-status');

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!status || !(form instanceof HTMLFormElement)) return;

		const button = form.querySelector('button[type="submit"]');
		if (!(button instanceof HTMLButtonElement)) return;
		button.disabled = true;
		status.classList.remove('hidden', 'text-teal-400', 'text-red-400');
		status.textContent = 'Sending...';

		try {
			const response = await fetch(form.action, {
				method: 'POST',
				body: new FormData(form),
			});
			const data = await response.json();

			if (data.success) {
				status.textContent = 'Thank you! We will get back to you soon.';
				status.classList.add('text-teal-400');
				form.reset();
			} else {
				throw new Error('Submission failed');
			}
		} catch {
			status.textContent = 'Something went wrong. Please email us directly.';
			status.classList.add('text-red-400');
		} finally {
			button.disabled = false;
		}
	});
</script>
